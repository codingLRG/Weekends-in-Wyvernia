filters:
  and:
    - file.folder.startsWith("Bestiary")
views:
  - type: table
    name: Table
    order:
      - file.name
      - Source
      - Size
      - Type
      - Alignment
      - AC
      - HP
      - Strength
      - Dexterity
      - Constitution
      - Intelligence
      - Wisdom
      - Charisma
      - Damage Vulnerabilities
      - Damage Resistances
      - Damage Immunities
      - Condition Immunities
      - Languages
      - CR
      - Environment
